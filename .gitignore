# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# package manager logs and caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.pnpm-store/
.yarn-integrity

# testing
/coverage
*.lcov

# next.js
/.next/
/out/
next-env.d.ts

# turbopack
.turbo

# production
/build
/dist

# typescript
*.tsbuildinfo

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# firebase
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
database-debug.log*
pubsub-debug.log*
