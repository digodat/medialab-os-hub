*-service-account.json
serviceAccountKey.json
firebase-adminsdk*.json

# playwright / mcp artifacts
.playwright-mcp/
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# logs
logs
*.log

# caches
.cache/
.eslintcache
.stylelintcache

# editor / IDE
.vscode/*
